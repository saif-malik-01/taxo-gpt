# =============================================================================
#  GST Injection API — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to git.
# =============================================================================


# -----------------------------------------------------------------------------
#  JWT Authentication
#  Used by: api/config.py → JWTConfig
# -----------------------------------------------------------------------------

# Strong random secret — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-random-64-char-hex-string

# Token lifetime in minutes. Default = 480 (8 hours) — internal admin tool.
JWT_EXPIRE_MINUTES=480


# -----------------------------------------------------------------------------
#  Admin Credentials
#  Used by: api/config.py → AdminConfig | api/auth.py
#
#  Only ONE admin user is supported right now (extend to DB later).
#  Password is stored as a bcrypt hash — NEVER store plaintext.
#
#  Generate hash with:
#    python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
# -----------------------------------------------------------------------------

ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$12$REPLACE_THIS_WITH_A_REAL_BCRYPT_HASH


# -----------------------------------------------------------------------------
#  Redis  (Celery broker + result backend)
#  Used by: api/config.py → RedisConfig | worker/celery_app.py
# -----------------------------------------------------------------------------

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# How long (seconds) to keep Celery job results before they expire.
# Default = 86400 (24 hours). Set lower in production to save memory.
JOB_TTL_SECONDS=86400


# -----------------------------------------------------------------------------
#  AWS Credentials
#  Used by: boto3 (Bedrock embedding + autofill) implicitly via environment.
#  boto3 picks these up automatically — no explicit read in config.py needed.
# -----------------------------------------------------------------------------

AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# Primary region — used for BOTH Titan embeddings and autofill LLM calls.
AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
#  AWS Bedrock — Titan Embeddings
#  Used by: flow/config.py → BedrockConfig | core_models/embedding_generator.py
# -----------------------------------------------------------------------------

# Titan embedding model. v2 supports 256/512/1024 dimensions.
TITAN_MODEL_ID=amazon.titan-embed-text-v2:0

# Output embedding dimensions. Must match your Qdrant collection vector size.
# Choices: 256 | 512 | 1024
TITAN_DIMENSIONS=1024

# Whether to L2-normalise vectors before storing. Keep True for cosine similarity.
TITAN_NORMALIZE=True


# -----------------------------------------------------------------------------
#  AWS Bedrock — Autofill LLM
#  Used by: api/config.py → BedrockAutofillConfig | autofill/bedrock_caller.py
#
#  This is the model used for the /chunks/autofill endpoint.
#  Defaults to Amazon Nova Pro — switch to your preferred model ARN.
# -----------------------------------------------------------------------------

# Options (cross-region inference profiles):
#   us.amazon.nova-pro-v1:0           ← default, good JSON accuracy
#   us.meta.llama3-3-70b-instruct-v1:0
#   <your-qwen3-custom-arn>            ← if available in your account
AUTOFILL_MODEL_ID=us.amazon.nova-pro-v1:0
# Alias also accepted (aws/config.py checks both):
# AWS_MODEL_ID=us.amazon.nova-pro-v1:0

# Max output tokens for the autofill LLM. 4096 is enough for single chunks.
# Increase to 8192 if you use split=True for large sections.
AUTOFILL_MAX_TOKENS=4096

# Temperature for LLM. Keep low (0.0–0.2) for structured JSON output.
AUTOFILL_TEMPERATURE=0.1


# -----------------------------------------------------------------------------
#  Qdrant Vector Database
#  Used by: flow/config.py → QdrantConfig | core_models/qdrant_manager.py
# -----------------------------------------------------------------------------

# Hostname of your Qdrant instance.
# Local docker:   localhost
# Qdrant Cloud:   <cluster-id>.us-east4-0.gcp.cloud.qdrant.io
QDRANT_HOST=localhost
QDRANT_PORT=6333

# API key — required for Qdrant Cloud, leave blank for local unauthenticated.
QDRANT_API_KEY=

# Set True if using Qdrant Cloud (HTTPS) or a TLS-terminated proxy.
QDRANT_HTTPS=False

# Collection and vector names — must match your existing Qdrant collection.
QDRANT_COLLECTION=gst_chunks
QDRANT_TEXT_VECTOR=text_vector
QDRANT_SUMMARY_VECTOR=summary_vector
QDRANT_SPARSE_VECTOR=bm25_sparse


# -----------------------------------------------------------------------------
#  BM25 Sparse Vectorizer
#  Used by: flow/config.py → BM25Config | flow/bm25_vectorizer.py
#  Sensible defaults — only change if you re-tune the retrieval model.
# -----------------------------------------------------------------------------

BM25_K1=1.5
BM25_B=0.75
BM25_L1_WEIGHT=3
BM25_L3_WEIGHT=1


# -----------------------------------------------------------------------------
#  File Paths
#  Used by: flow/config.py → PathConfig | worker/tasks.py
# -----------------------------------------------------------------------------

# Where processed chunk files live (used by batch pipeline, not the API).
CHUNKS_DIR=./data/processed

# File tracker JSON — records which source files have been ingested.
TRACKER_FILE=./ingestion_tracker.json

# Debug token output directory (set WRITE_DEBUG_TOKENS=False to disable).
DEBUG_DIR=./debug_tokens

# BM25 corpus statistics — updated by the Celery worker on each ingestion.
# Must be the SAME file shared between the API worker and batch pipeline.
CORPUS_STATS_FILE=./corpus_stats.json


# -----------------------------------------------------------------------------
#  Pipeline Behaviour
#  Used by: flow/config.py → PipelineConfig
# -----------------------------------------------------------------------------

PIPELINE_MAX_RETRIES=3
PIPELINE_RETRY_DELAY=2.0

# Set False in production to skip writing token debug files.
WRITE_DEBUG_TOKENS=False
