# --- AWS Bedrock ---
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
TITAN_MODEL_ID="amazon.titan-embed-text-v2:0"
TITAN_DIMENSIONS=1024
TITAN_NORMALIZE=True

# --- Qdrant ---
QDRANT_HOST="localhost"
QDRANT_PORT=6333
QDRANT_API_KEY=""
QDRANT_COLLECTION="gst_chunks"

# --- BM25 (Sparse Vectors) ---
BM25_K1=1.5
BM25_B=0.75
BM25_L1_WEIGHT=3
BM25_L3_WEIGHT=1

# --- Paths ---
CHUNKS_DIR="./data/processed"
TRACKER_FILE="./ingestion_tracker.json"
DEBUG_DIR="./debug_tokens"
CORPUS_STATS_FILE="./corpus_stats.json"

# --- Pipeline Control ---
PIPELINE_MAX_RETRIES=3
PIPELINE_RETRY_DELAY=2.0
WRITE_DEBUG_TOKENS=True
