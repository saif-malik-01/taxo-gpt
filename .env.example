DATABASE_URL="postgresql+asyncpg://postgres:admin@localhost:5432/taxogpt"

REDIS_URL="redis://localhost:6379/0"

PROJECT_NAME="Taxobuddy"
API_V1_STR="/api/v1"

JWT_SECRET_KEY="supersecretkey"
JWT_ALGORITHM="HS256"
API_KEY_SECRET="taxogpt-internal-api-key"
ACCESS_TOKEN_EXPIRE_MINUTES=30

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=""
SMTP_PASSWORD=""
FEEDBACK_RECIPIENT_EMAIL="atul@gmail.com"

GOOGLE_CLIENT_ID=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""

RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

QDRANT_HOST="localhost"
QDRANT_PORT=6333
QDRANT_API_KEY=""
QDRANT_TIMEOUT=20
QDRANT_COLLECTION="gst_chunks"
QDRANT_HTTPS=False
QDRANT_TEXT_VECTOR="text_vector"
QDRANT_SPARSE_VECTOR="sparse_vector"

# --- Path for BM25 Stats ---
CORPUS_STATS_FILE="corpus_stats.json"

AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET="taxobuddy-docs"
WORKER_URL="http://localhost:8001"

FRONTEND_URL="http://localhost:3000"

GLOBAL_MONTHLY_TOKEN_LIMIT=1000000
SESSION_TOKEN_LIMIT_DRAFT=60000
SESSION_TOKEN_LIMIT_SIMPLE=100000

# Logging
LOG_LEVEL="INFO"
LOG_FILE="logs/app.log"

# BM25 Configuration
BM25_K1=1.5
BM25_B=0.75
BM25_L1_WEIGHT=3
BM25_L3_WEIGHT=1

# Bedrock Configuration
TITAN_MODEL_ID="amazon.titan-embed-text-v2:0"
TITAN_DIMENSIONS=1024
TITAN_NORMALIZE=True
PIPELINE_MAX_RETRIES=3
PIPELINE_RETRY_DELAY=2.0